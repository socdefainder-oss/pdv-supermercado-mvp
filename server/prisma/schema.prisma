generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CASHIER
}

enum ProductUnit {
  UN
  KG
  CX
  LT
  ML
  PCT
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  SUPPLY
  WITHDRAW
}

enum SaleStatus {
  COMPLETED
  CANCELED
}

enum DiscountType {
  NONE
  FIXED
  PERCENTAGE
}

enum PaymentMethod {
  CASH
  DEBIT_CARD
  CREDIT_CARD
  PIX
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  CANCELATION
  LOSS
}

enum PurchaseOrderStatus {
  OPEN
  RECEIVED
  CANCELED
}

enum InventoryStatus {
  OPEN
  CLOSED
}

enum PriceTableStatus {
  ACTIVE
  INACTIVE
}

enum CustomerCreditStatus {
  OPEN
  PAID
  CANCELED
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  passwordHash   String
  role           UserRole
  active         Boolean        @default(true)
  permissions    String[]       @default([])
  discountLimitCents Int        @default(2000)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  cashRegisters  CashRegister[]
  sales          Sale[]
  cashMovements  CashMovement[]
  stockMovements StockMovement[]
  auditLogs      AuditLog[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  document  String?  @unique
  phone     String?
  email     String?
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales     Sale[]
  credits   CustomerCredit[]

  @@index([name])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  document  String?  @unique
  phone     String?
  email     String?
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  purchaseOrders PurchaseOrder[]

  @@index([name])
}

model Employee {
  id        String   @id @default(cuid())
  name      String
  document  String?  @unique
  roleName  String
  phone     String?
  email     String?
  commissionPercent Decimal @default(0) @db.Decimal(5, 2)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id              String          @id @default(cuid())
  name            String
  barcode         String          @unique
  categoryId      String
  unit            ProductUnit
  costPriceCents  Int
  salePriceCents  Int
  stockQuantity   Decimal         @db.Decimal(12, 3)
  minStock        Decimal         @db.Decimal(12, 3)
  location         String?
  lot              String?
  expiresAt        DateTime?
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  category        Category        @relation(fields: [categoryId], references: [id])
  saleItems       SaleItem[]
  stockMovements  StockMovement[]
  inventoryItems  InventoryItem[]
  purchaseItems   PurchaseOrderItem[]
  promotions      Promotion[]
  priceItems      PriceTableItem[]

  @@index([name])
  @@index([categoryId])
}

model CashRegister {
  id                  String              @id @default(cuid())
  operatorId          String
  openingAmountCents  Int
  closingAmountCents  Int?
  expectedCashCents   Int?
  differenceCents     Int?
  status              CashRegisterStatus  @default(OPEN)
  openedAt            DateTime            @default(now())
  closedAt            DateTime?
  operator            User                @relation(fields: [operatorId], references: [id])
  movements           CashMovement[]
  sales               Sale[]

  @@index([operatorId, status])
}

model CashMovement {
  id             String           @id @default(cuid())
  cashRegisterId String
  type           CashMovementType
  amountCents    Int
  reason         String
  userId         String
  createdAt      DateTime         @default(now())
  cashRegister   CashRegister     @relation(fields: [cashRegisterId], references: [id])
  user           User             @relation(fields: [userId], references: [id])
}

model Sale {
  id                String        @id @default(cuid())
  cashRegisterId    String
  operatorId        String
  customerId        String?
  grossTotalCents   Int
  discountType      DiscountType  @default(NONE)
  discountValue     Decimal       @default(0) @db.Decimal(12, 2)
  discountTotalCents Int          @default(0)
  netTotalCents     Int
  status            SaleStatus    @default(COMPLETED)
  canceledAt        DateTime?
  cancelReason      String?
  createdAt         DateTime      @default(now())
  cashRegister      CashRegister  @relation(fields: [cashRegisterId], references: [id])
  operator          User          @relation(fields: [operatorId], references: [id])
  customer          Customer?     @relation(fields: [customerId], references: [id])
  items             SaleItem[]
  payments          Payment[]
  stockMovements    StockMovement[]
  credits           CustomerCredit[]

  @@index([createdAt])
  @@index([operatorId])
}

model SaleItem {
  id             String   @id @default(cuid())
  saleId         String
  productId      String
  quantity       Decimal  @db.Decimal(12, 3)
  unitPriceCents Int
  discountCents  Int      @default(0)
  subtotalCents  Int
  sale           Sale     @relation(fields: [saleId], references: [id])
  product        Product  @relation(fields: [productId], references: [id])
}

model Payment {
  id             String        @id @default(cuid())
  saleId         String
  method         PaymentMethod
  amountCents    Int
  changeCents    Int           @default(0)
  createdAt      DateTime      @default(now())
  sale           Sale          @relation(fields: [saleId], references: [id])
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  type        StockMovementType
  quantity    Decimal           @db.Decimal(12, 3)
  reason      String
  saleId      String?
  userId      String
  lot         String?
  expiresAt   DateTime?
  createdAt   DateTime          @default(now())
  product     Product           @relation(fields: [productId], references: [id])
  sale        Sale?             @relation(fields: [saleId], references: [id])
  user        User              @relation(fields: [userId], references: [id])

  @@index([productId, createdAt])
}

model Inventory {
  id        String          @id @default(cuid())
  status    InventoryStatus @default(OPEN)
  notes     String?
  userId    String
  createdAt DateTime        @default(now())
  closedAt  DateTime?
  items     InventoryItem[]
}

model InventoryItem {
  id             String    @id @default(cuid())
  inventoryId    String
  productId      String
  countedQuantity Decimal  @db.Decimal(12, 3)
  systemQuantity Decimal   @db.Decimal(12, 3)
  difference     Decimal   @db.Decimal(12, 3)
  inventory      Inventory @relation(fields: [inventoryId], references: [id])
  product        Product   @relation(fields: [productId], references: [id])
}

model PurchaseOrder {
  id            String              @id @default(cuid())
  supplierId    String
  status        PurchaseOrderStatus @default(OPEN)
  totalCents    Int                 @default(0)
  notes         String?
  createdAt     DateTime            @default(now())
  receivedAt    DateTime?
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  items         PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Decimal       @db.Decimal(12, 3)
  costPriceCents  Int
  subtotalCents   Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product         Product       @relation(fields: [productId], references: [id])
}

model Promotion {
  id                 String   @id @default(cuid())
  productId          String
  description        String
  discountPercent    Decimal? @db.Decimal(5, 2)
  discountCents      Int?
  startsAt           DateTime
  endsAt             DateTime
  active             Boolean  @default(true)
  product            Product  @relation(fields: [productId], references: [id])
}

model PriceTable {
  id        String           @id @default(cuid())
  name      String
  status    PriceTableStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  items     PriceTableItem[]
}

model PriceTableItem {
  id             String     @id @default(cuid())
  priceTableId   String
  productId      String
  salePriceCents Int
  priceTable     PriceTable @relation(fields: [priceTableId], references: [id])
  product        Product    @relation(fields: [productId], references: [id])
}

model CustomerCredit {
  id          String               @id @default(cuid())
  customerId  String
  saleId      String?
  amountCents Int
  paidCents   Int                  @default(0)
  dueDate     DateTime?
  status      CustomerCreditStatus @default(OPEN)
  createdAt   DateTime             @default(now())
  customer    Customer             @relation(fields: [customerId], references: [id])
  sale        Sale?                @relation(fields: [saleId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([entity, createdAt])
}
